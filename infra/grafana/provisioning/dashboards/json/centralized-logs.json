{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Stream — $service / $level",
      "type": "logs",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"$level\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "wrapLogMessage": true
      }
    },
    {
      "title": "Error Rate by Service (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\", level=\"ERROR\"} [1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "Log Volume by Service (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} [1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "Log Level Distribution (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({service=~\"$service\"} [1m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      }
    },
    {
      "title": "WARN + ERROR Logs",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\"$service\", level=~\"WARN|ERROR\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "wrapLogMessage": true
      }
    },
    {
      "title": "Trace Lookup — Paste traceId",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 30 },
      "datasource": { "type": "loki", "uid": "" },
      "targets": [
        {
          "expr": "{service=~\".+\"} |= `$traceId`",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Ascending",
        "enableLogDetails": true,
        "wrapLogMessage": true
      }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["data-standardization", "loki", "tracing"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "label": "Service",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "api-gateway", "value": "api-gateway", "selected": false },
          { "text": "eureka-server", "value": "eureka-server", "selected": false },
          { "text": "data-ingestion-service", "value": "data-ingestion-service", "selected": false },
          { "text": "rule-engine-service", "value": "rule-engine-service", "selected": false },
          { "text": "standardization-service", "value": "standardization-service", "selected": false }
        ],
        "query": "api-gateway,eureka-server,data-ingestion-service,rule-engine-service,standardization-service",
        "allValue": ".+"
      },
      {
        "name": "level",
        "type": "custom",
        "label": "Log Level",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "DEBUG", "value": "DEBUG", "selected": false },
          { "text": "INFO", "value": "INFO", "selected": false },
          { "text": "WARN", "value": "WARN", "selected": false },
          { "text": "ERROR", "value": "ERROR", "selected": false }
        ],
        "query": "DEBUG,INFO,WARN,ERROR",
        "allValue": ".+"
      },
      {
        "name": "traceId",
        "type": "textbox",
        "label": "Trace ID",
        "current": { "value": "" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Data Standardization — Centralized Logs & Tracing",
  "uid": "datastd-logs"
}

