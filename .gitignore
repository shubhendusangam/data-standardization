# ═══════════════════════════════════════════════════════════
#  Data Standardization Pipeline — .gitignore
# ═══════════════════════════════════════════════════════════

# ── Maven Build Output ─────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ── IDE — IntelliJ IDEA ───────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/

# ── IDE — Eclipse ─────────────────────────────────────────
.classpath
.project
.settings/
.factorypath
bin/

# ── IDE — VS Code ─────────────────────────────────────────
.vscode/

# ── IDE — NetBeans ─────────────────────────────────────────
nbproject/
nbbuild/
nbdist/
nb-configuration.xml

# ── OS Files ───────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
*~

# ── Logs ───────────────────────────────────────────────────
*.log
logs/
spring.log

# ── H2 Database Files ─────────────────────────────────────
*.db
*.mv.db
*.trace.db

# ── Environment & Secrets ─────────────────────────────────
.env
.env.*
*.env
!*.env.example
application-local.yml
application-local.properties
application-secret*.yml
application-secret*.properties

# ── Docker ─────────────────────────────────────────────────
# Ignore Docker volume data that may be created locally
docker-data/
grafana-data/
loki-data/

# ── Grafana Runtime (if running outside Docker) ───────────
infra/grafana/data/

# ── Misc ───────────────────────────────────────────────────
*.swp
*.swo
*.bak
*.tmp
*.orig
.flattened-pom.xml
crash-*.log
hs_err_pid*

